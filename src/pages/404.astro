---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Cursed Tours"
  description="The page you're looking for doesn't exist or has been moved."
  noindex={true}
>
  <section class="min-h-[60vh] flex items-center justify-center py-20">
    <div class="text-center px-4 max-w-lg">
      <p class="text-6xl font-bold mb-4" style="color: #7c3aed; font-family: 'Cinzel', serif;">404</p>
      <h1 class="text-2xl md:text-3xl font-bold text-white mb-4">Page Not Found</h1>
      <p class="text-gray-400 mb-8 leading-relaxed">
        The page you're looking for doesn't exist or has been moved.
        It may have been part of an older version of the site.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold text-white transition-all"
          style="background: linear-gradient(135deg, #7c3aed, #a855f7);"
        >
          Back to Home
        </a>
        <a
          href="/articles/"
          class="inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 text-sm font-semibold transition-all"
          style="color: #c8bdd8; border: 1px solid #3d2a4d;"
        >
          Browse Articles
        </a>
      </div>
    </div>
  </section>
</Layout>
